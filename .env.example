# ── B2B Intel — Environment Variables ──────────────────────────────────────
# Copy this file to .env and fill in your values
# Never commit .env to GitHub!

# ── Database ────────────────────────────────────────────────────────────────
# Option A: SQLite (local development — no setup needed)
# DATABASE_URL=sqlite:///./data/b2b_intel.db

# Option B: Supabase PostgreSQL (production)
# Get this from: Supabase Dashboard → Project Settings → Database → Connection String
# DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT].supabase.co:5432/postgres

DATABASE_URL=postgresql://postgres:ManojBisht31@db.hdodsqhmzfogtrskbaon.supabase.co:5432/postgres

# ── AI Bonus Layer (optional) ───────────────────────────────────────────────
# Get from: https://platform.openai.com/api-keys
# Leave blank to use the free rule-based fallback
OPENAI_API_KEY=

# ── API Settings ─────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
